        {
          "text": "と指示した場合、生成物が元の作品に酷似していれば、",
          "startMs": 40729,
          "endMs": 44361
        },
        {
          "text": "立派な著作権侵害になり得ます。",
          "startMs": 44361,
          "endMs": 46540
        },
        {
          "text": "「AIが勝手に作った」という言い訳は通用しません。",
          "startMs": 46540,
          "endMs": 50420
        }
      ],
      "durationSec": 50.44,
      "durationFrames": 1514,
      "startFrame": 12481,
      "gapAfterFrames": 30
    },
    {
      "id": 15,
